# Laravel
/vendor
/node_modules
/public/hot
/public/storage
# /public/build is intentionally tracked — we build assets locally and ship
# the dist/ to the server, since Cloudways' bundled npm chokes on our
# package-lock.json v3 format. Remove this comment and re-ignore /public/build
# once we have a working server-side build pipeline (e.g. GitHub Action).
/storage/*.key
/storage/pail
/bootstrap/cache/*.php
.phpunit.cache
.phpunit.result.cache

# Laravel framework runtime caches — must never be tracked
/storage/framework/cache/data/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/framework/testing/*
!/storage/framework/cache/data/.gitkeep
!/storage/framework/sessions/.gitkeep
!/storage/framework/views/.gitkeep

# User-generated artifacts (regenerated server-side)
/storage/app/public/*
/storage/app/timesheets/*.pdf

# Env + secrets
.env
.env.backup
.env.production
.env.*.local
auth.json

# Editor / OS
.idea
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
/storage/logs/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local Homestead / Sail
/.homestead
Homestead.json
Homestead.yaml
.vagrant

# Generated PDFs (keep in storage on the server, not in repo)
/storage/app/reports/*.pdf

# Cloudways deploy artifacts
.cloudways/
